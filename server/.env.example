# =========================
# CarbonX — Environment Variables Example
# =========================
# Copy this file to .env and fill in your actual values

# =========================
# Server Configuration
# =========================
NODE_ENV=development
PORT=5000

# =========================
# MongoDB
# =========================
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.inesrof.mongodb.net/carbonDB

# =========================
# JWT Authentication
# =========================
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_EXPIRES_IN=7d

# =========================
# Email Service (SMTP)
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=CarbonX <no-reply@carbonx.com>

# =========================
# API Keys - AI Services
# =========================

# OpenAI (Primary / Fallback)
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_MODEL=gpt-4o-mini

# Qwen via LM Studio (Local)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen/qwen3-vl-4b

# =========================
# Pinecone Vector Database (RAG for AI Advisor)
# =========================
PINECONE_API_KEY=pcsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PINECONE_INDEX_NAME=carbon-advisory-rag
PINECONE_NAMESPACE=carbon-corpus
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# =========================
# OpenAI Embeddings
# =========================
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# =========================
# External APIs
# =========================
NEWS_API_KEY=your_newsapi_org_key_here

# Google Translate API (optional - if using official API)
# GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# =========================
# Chunking & Retrieval Configuration
# =========================
CHUNK_SIZE=1000
CHUNK_OVERLAP=180
TOP_K_MIN=3
TOP_K_MAX=8
RETRIEVAL_CANDIDATE_MULTIPLIER=3
REQUEST_TIMEOUT_SECONDS=35
